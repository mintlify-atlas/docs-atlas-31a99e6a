  "keyFeatures": [
    "Register traffic violations with municipality and device identification",
    "Offline operation support with expedition number ranges",
    "Master data synchronization for municipalities, violations, and vehicle data",
    "Certificate-based HTTPS authentication",
    "Query and cancel violations",
    "Device and agent authentication management"
  ],
  "publicApiSurface": [
    "POST /AltaMulta - Register a traffic violation",
    "GET /Consulta - Query a violation by municipality and expedition number",
    "GET /AltaAnulada - Cancel a previously registered violation",
    "GET /FerLogin - Authenticate agent and device",
    "GET /ObtenirRang - Request expedition number ranges for offline work",
    "GET /ObtenirActualitzacions - Fetch master data updates",
    "GET /ObtenirMunicipis - Get list of municipalities with ORGT and INE codes",
    "GET /ObtenirEscuts - Download municipality coat of arms images",
    "GET /CanviPassword - Change agent password",
    "POST /AltaInci - Register a public road incident"
  ]
